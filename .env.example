# CricInsight environment configuration
# Copy to .env and fill in real values. .env is gitignored.

# --- Database ---
# Local docker-compose: cricinsight/cricinsight on localhost:5432
# AWS RDS: replace with the endpoint exported by terraform output
DATABASE_URL=postgresql+asyncpg://cricinsight:cricinsight@localhost:5432/cricinsight

# Sync URL for Alembic (psycopg2 driver — Alembic doesn't need async)
DATABASE_URL_SYNC=postgresql+psycopg2://cricinsight:cricinsight@localhost:5432/cricinsight

# --- CricAPI ---
# Register at https://cricapi.com for a free key (100 calls/day).
# During development, the ingestion client caches responses to backend/ingestion/.cache/
# so repeated runs don't burn quota.
CRICAPI_KEY=your_cricapi_key_here
CRICAPI_BASE_URL=https://api.cricapi.com/v1

# --- AWS (only needed for terraform apply) ---
AWS_REGION=us-east-1

# --- App ---
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

# CORS — comma-separated origins allowed to hit the API
CORS_ORIGINS=http://localhost:3000
