# Vite picks this up automatically when running in development mode
# (`npm run dev`). VITE_-prefixed variables are exposed to client-side
# code via import.meta.env.VITE_API_URL.
#
# This file is checked in — it carries the dev defaults every contributor
# should use. For per-developer overrides, create .env.development.local
# (gitignored). For Phase 6.4 (AWS deploy), build with VITE_API_URL set
# to the load-balancer DNS name; .env.production gets the prod default.
VITE_API_URL=http://localhost:8000
